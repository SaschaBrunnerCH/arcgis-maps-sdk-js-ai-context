{
  "name": "arcgis-maps-sdk-js-ai-context",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Agent Skills for ArcGIS Maps SDK for JavaScript development",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "spellcheck": "cspell \"**/*.md\" --no-progress",
    "lint:markdown": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "validate:skills": "node scripts/validate-skills.js",
    "check": "npm run format:check && npm run spellcheck && npm run lint:markdown && npm run validate:skills",
    "setup": "node scripts/setup-hooks.js",
    "postinstall": "node scripts/setup-hooks.js"
  },
  "keywords": [
    "arcgis",
    "esri",
    "gis",
    "agent-skills",
    "claude",
    "copilot",
    "ai",
    "skills",
    "maps",
    "javascript"
  ],
  "author": "Sascha Brunner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SaschaBrunnerCH/arcgis-maps-sdk-js-ai-context.git"
  },
  "bugs": {
    "url": "https://github.com/SaschaBrunnerCH/arcgis-maps-sdk-js-ai-context/issues"
  },
  "homepage": "https://github.com/SaschaBrunnerCH/arcgis-maps-sdk-js-ai-context#readme",
  "devDependencies": {
    "cspell": "^8.17.0",
    "markdownlint-cli2": "^0.17.0",
    "prettier": "^3.4.0"
  }
}
